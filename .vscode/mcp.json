{
	"servers": {
		"cognitionai/deepwiki": {
			"type": "http",
			"url": "https://mcp.deepwiki.com/mcp"
		},

		"git": {
			"command": "sh",
			"args": [
				"-c",
				"touch ~/.gitconfig; touch ~/.gitignore_global; docker run --rm -i --mount type=bind,src=${workspaceFolder},dst=${workspaceFolder} -v ~/.gitconfig:/root/.gitconfig -v ~/.gitignore_global:/root/.gitignore_global mcp/git"
			]
        }
	}
}
